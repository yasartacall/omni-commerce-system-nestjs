{
  "info": {
    "name": "Omni Commerce System",
    "_postman_id": "omni-commerce-v1",
    "description": "NestJS Microservices E-Commerce API — API Gateway (port 3000)\n\nSaga Flow:\n1. Register / Login → get JWT token\n2. Create products (admin)\n3. Create order → triggers Kafka Saga (stock check → payment → stock deduct)\n4. Poll GET /orders/:id to track saga status",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000/api",
      "type": "string"
    },
    {
      "key": "product_base",
      "value": "http://localhost:3001/api",
      "type": "string"
    },
    {
      "key": "order_base",
      "value": "http://localhost:3002/api",
      "type": "string"
    },
    { "key": "token", "value": "", "type": "string" },
    { "key": "product_id", "value": "", "type": "string" },
    { "key": "order_id", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"Password123!\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('token', body.accessToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"Password123!\"\n}"
            }
          }
        },
        {
          "name": "Login (Wrong Password)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"wrong\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Create Product",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('product_id', body.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{product_base}}/products",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Laptop Pro 16\",\n  \"description\": \"High performance laptop\",\n  \"price\": 1299.99,\n  \"stockQuantity\": 100\n}"
            }
          }
        },
        {
          "name": "Get All Products",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns array', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{product_base}}/products"
          }
        },
        {
          "name": "Get Product by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{product_base}}/products/{{product_id}}"
          }
        },
        {
          "name": "Update Product",
          "request": {
            "method": "PATCH",
            "url": "{{product_base}}/products/{{product_id}}",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 1199.99\n}"
            }
          }
        },
        {
          "name": "Update Stock",
          "request": {
            "method": "PATCH",
            "url": "{{product_base}}/products/{{product_id}}/stock",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"stockQuantity\": 50\n}"
            }
          }
        },
        {
          "name": "Get Product (Invalid UUID)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{product_base}}/products/not-a-uuid"
          }
        },
        {
          "name": "Delete Product",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 204', () => pm.response.to.have.status(204));"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "url": "{{product_base}}/products/{{product_id}}"
          }
        }
      ]
    },
    {
      "name": "Orders (Saga)",
      "item": [
        {
          "name": "Create Order (triggers Saga)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('order_id', body.id);",
                  "pm.test('Status is PROCESSING', () => pm.expect(body.status).to.equal('PROCESSING'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{order_base}}/orders",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    {\n      \"productId\": \"{{product_id}}\",\n      \"quantity\": 2,\n      \"unitPrice\": 1299.99\n    }\n  ]\n}"
            }
          }
        },
        {
          "name": "Get My Orders",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{order_base}}/orders",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get Order by ID (poll for saga completion)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "console.log('Order status:', body.status);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{order_base}}/orders/{{order_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Create Order (No Auth → 401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{order_base}}/orders",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [{ \"productId\": \"{{product_id}}\", \"quantity\": 1, \"unitPrice\": 100 }]\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Rate Limiting",
      "item": [
        {
          "name": "Trigger Rate Limit (run 11+ times)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Run this request 11+ times to trigger 429",
                  "if (pm.response.code === 429) {",
                  "  pm.test('Rate limit triggered', () => pm.response.to.have.status(429));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{product_base}}/products"
          }
        }
      ]
    }
  ]
}
